# ─── multi_strategy_v1（5 策略 ensemble；ENV 開關，預設關閉以保留 baseline 行為） ──
# 詳細說明見 MULTI_STRATEGY_DESIGN.md
MULTI_STRATEGY_ENABLED=
MULTI_STRATEGY_VERSION=
STRATEGY_WEIGHT_TREND=
STRATEGY_WEIGHT_BALANCE=
STRATEGY_WEIGHT_ANTI_CONCENTRATION=
STRATEGY_WEIGHT_REVERSION=
STRATEGY_WEIGHT_COVERAGE=
MULTI_STRATEGY_MIN_SUPPORT_FACTOR=
MULTI_STRATEGY_MAX_HOT_RATIO=
MULTI_STRATEGY_MIN_MID_COLD_RATIO=
MULTI_STRATEGY_RECENT_RECOMMEND_WINDOW=
MULTI_STRATEGY_PAIR_REPEAT_PENALTY=
MULTI_STRATEGY_TRIPLE_REPEAT_PENALTY=
MULTI_STRATEGY_REVERSION_BONUS=
MULTI_STRATEGY_COVERAGE_BONUS=

# ─── ensemble_voting_v1（真正 meta voting 投票層；ENV 開關，預設關閉） ─────
# 詳細說明見 ENSEMBLE_VOTING_DESIGN.md（Phase 3 文件）。
# 與 multi_strategy_v1 不衝突：兩者可疊用，ensemble_voting 在 multi_strategy 之後跑。
# 影響 prediction：是。Local/Cloud 都用。Production 是否設由你決定。
# Rollback：將 ENSEMBLE_VOTING_ENABLED 改為空或 false 即可。
ENSEMBLE_VOTING_ENABLED=
ENSEMBLE_VOTING_VERSION=
ENSEMBLE_TOP_K=
ENSEMBLE_MIN_SUPPORT_STRATEGIES=
ENSEMBLE_TREND_ONLY_PENALTY=
ENSEMBLE_MAX_TREND_ONLY_TOP10_RATIO=
ENSEMBLE_PAIR_LOCK_PENALTY=
ENSEMBLE_TRIPLE_LOCK_PENALTY=
ENSEMBLE_DOMINANCE_WINDOW=
ENSEMBLE_PAIR_LOCK_WINDOW=
ENSEMBLE_PAIR_LOCK_MAX_REPEAT=
ENSEMBLE_TRIPLE_LOCK_WINDOW=
ENSEMBLE_TRIPLE_LOCK_MAX_REPEAT=
ENSEMBLE_COVERAGE_TARGET=
ENSEMBLE_MAX_SINGLE_STRATEGY_DOMINANCE=
ENSEMBLE_STRATEGY_WEIGHT_TREND=
ENSEMBLE_STRATEGY_WEIGHT_BALANCE=
ENSEMBLE_STRATEGY_WEIGHT_ANTI_CONCENTRATION=
ENSEMBLE_STRATEGY_WEIGHT_REVERSION=
ENSEMBLE_STRATEGY_WEIGHT_COVERAGE=

# ─── Phase 2.5：核心群／號碼曝光控制（避免「同一群號碼一直輪替」） ──────
# 詳細說明見 ENSEMBLE_VOTING_COMPARE.md。所有 ENV 都是可選；空 = 使用預設值。
# 影響 prediction：是。Local/Cloud 都用。
# Rollback：清空即可回到 Phase 2 行為。
ENSEMBLE_NUMBER_EXPOSURE_WINDOW=
ENSEMBLE_NUMBER_EXPOSURE_MAX_REPEAT=
ENSEMBLE_NUMBER_EXPOSURE_PENALTY=
ENSEMBLE_HOT_TOP10_MAX_RATIO=
ENSEMBLE_HOT_TOP10_PENALTY=
ENSEMBLE_CORE_GROUP_PENALTY=
ENSEMBLE_CORE_GROUP_WINDOW=
ENSEMBLE_CORE_GROUP_MAX_EXPOSURE=
ENSEMBLE_CONSENSUS_PROTECTION_MIN_SUPPORT=
ENSEMBLE_CONSENSUS_PROTECTION_FACTOR=

# ─── Candidate Config — Variant C（Phase 2.5 推薦候選；預設仍 OFF） ────────
# 詳見 ENSEMBLE_VOTING_COMPARE.md。本變體用 exposure penalty + consensus
# protection 做有邏輯輪替；不是 random / 不是 blacklist / 不禁止任何號碼。
# Production 預設不要直接開；建議本機 cloud-readonly 或 Vercel Preview 觀察 1-2 週。
# 啟用時複製下面 6 個值並去掉 "#"；不啟用就保持原樣。
# ENSEMBLE_VOTING_ENABLED=true
# ENSEMBLE_VOTING_VERSION=ensemble_voting_v1
# ENSEMBLE_NUMBER_EXPOSURE_MAX_REPEAT=3
# ENSEMBLE_NUMBER_EXPOSURE_PENALTY=0.75
# ENSEMBLE_CORE_GROUP_MAX_EXPOSURE=3
# ENSEMBLE_CORE_GROUP_PENALTY=0.78

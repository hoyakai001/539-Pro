{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "docs/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 14 * * *"
    }
  ]
}
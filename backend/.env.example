PORT=3001
NODE_ENV=development

# ─── 台灣彩券官方 URL ──────────────────────────────────────
# 若官方改版請在此更新，不要直接改原始碼
TW_LOTTERY_RESULT_URL=https://www.taiwanlottery.com/lotto/result/4_d/
TW_LOTTERY_HISTORY_DOWNLOAD_URL=https://www.taiwanlottery.com/lotto/history/result_download/
TW_LOTTERY_HISTORY_RESULT_URL=https://www.taiwanlottery.com/lotto/history/history_result/

# ─── 今彩539 API 端點 (台灣彩券後台 API，請用 DevTools Network 確認)
# 在瀏覽器開啟 https://www.taiwanlottery.com/lotto/result/4_d/
# 開 F12 → Network → XHR/Fetch，尋找含有開獎資料的 API 請求
# 將 URL 填入下方（留空則改用 HTML 解析）
TW_LOTTERY_API_LATEST=
TW_LOTTERY_API_HISTORY_BASE=

# ─── 資料庫路徑 ───────────────────────────────────────────
DB_PATH=./data/539.db


# ─── 同步排程（cron 格式，台灣時間 21:30 = UTC 13:30）──────
SYNC_CRON=30 13 * * *

# ─── multi_strategy_v1（5 策略 ensemble；ENV 開關，預設關閉） ─────
# 詳細說明：MULTI_STRATEGY_DESIGN.md
# MULTI_STRATEGY_ENABLED=true
# MULTI_STRATEGY_VERSION=multi_strategy_v1
# STRATEGY_WEIGHT_TREND=0.35
# STRATEGY_WEIGHT_BALANCE=0.20
# STRATEGY_WEIGHT_ANTI_CONCENTRATION=0.20
# STRATEGY_WEIGHT_REVERSION=0.15
# STRATEGY_WEIGHT_COVERAGE=0.10
# MULTI_STRATEGY_MIN_SUPPORT_FACTOR=0.40
# MULTI_STRATEGY_MAX_HOT_RATIO=0.60
# MULTI_STRATEGY_MIN_MID_COLD_RATIO=0.40
# MULTI_STRATEGY_RECENT_RECOMMEND_WINDOW=5
# MULTI_STRATEGY_PAIR_REPEAT_PENALTY=0.88
# MULTI_STRATEGY_TRIPLE_REPEAT_PENALTY=0.82
# MULTI_STRATEGY_REVERSION_BONUS=1.08
# MULTI_STRATEGY_COVERAGE_BONUS=1.06

# ─── ensemble_voting_v1（真正 meta voting；獨立於 multi_strategy_v1） ─────────
# 詳細說明：ENSEMBLE_VOTING_DESIGN.md（Phase 3 文件）
# 影響 prediction：是（重排 single/two/three/four/five_star）
# Local/Cloud：兩端都用；本機與雲端必須一致，否則 prediction drift
# Production：是否設由你決定；啟用後 cache schema 變更，舊 cache 自動失效
# 預設：關閉（commented out → baseline / multi_strategy_v1 行為不變）
# Rollback：將 ENSEMBLE_VOTING_ENABLED 移除或設為 false 即可回到上一層
#
# ENSEMBLE_VOTING_ENABLED=true                     # 總開關；預設 false（空）
# ENSEMBLE_VOTING_VERSION=ensemble_voting_v1       # cache schema 後綴
# ENSEMBLE_TOP_K=10                                # 每個 strategy 自選 topK 候選
# ENSEMBLE_MIN_SUPPORT_STRATEGIES=2                # 至少幾個 strategy 支持才不被 dominance penalty 懲罰
# ENSEMBLE_TREND_ONLY_PENALTY=0.72                 # trend-only 號的衰減倍率（0-1）
# ENSEMBLE_MAX_TREND_ONLY_TOP10_RATIO=0.35         # final top10 中 trend-only 比例上限；超過 → 再衰減一次
# ENSEMBLE_PAIR_LOCK_PENALTY=0.82                  # pair 重複觸發鎖定時的衰減倍率
# ENSEMBLE_TRIPLE_LOCK_PENALTY=0.78                # triple 重複觸發鎖定時的衰減倍率
# ENSEMBLE_DOMINANCE_WINDOW=5                      # 最近幾期 prediction 用於 dominance / pair / triple lock 統計
# ENSEMBLE_PAIR_LOCK_WINDOW=5                      # pair lock 統計視窗
# ENSEMBLE_PAIR_LOCK_MAX_REPEAT=2                  # 同一 pair 在視窗內出現 > 此值 → 觸發 pair lock
# ENSEMBLE_TRIPLE_LOCK_WINDOW=5                    # triple lock 統計視窗
# ENSEMBLE_TRIPLE_LOCK_MAX_REPEAT=1                # 同一 triple 出現 > 此值 → 觸發 triple lock
# ENSEMBLE_COVERAGE_TARGET=39                      # coverage strategy 的目標覆蓋數（diagnostic only）
# ENSEMBLE_MAX_SINGLE_STRATEGY_DOMINANCE=0.40      # 單一 strategy 在 top10 的 dominance 上限（diagnostic only）
# ENSEMBLE_STRATEGY_WEIGHT_TREND=0.22              # meta voting 的 strategy 權重（會 normalize）
# ENSEMBLE_STRATEGY_WEIGHT_BALANCE=0.22
# ENSEMBLE_STRATEGY_WEIGHT_ANTI_CONCENTRATION=0.22
# ENSEMBLE_STRATEGY_WEIGHT_REVERSION=0.17
# ENSEMBLE_STRATEGY_WEIGHT_COVERAGE=0.17

# ─── Phase 2.5：核心群／號碼曝光 soft penalty（用來壓抑核心群輪替） ──────
# 全部 deterministic 乘性懲罰；不 random、不 blacklist、不 hard ban。
# Consensus protection：若該號碼有 >= MIN_SUPPORT 個 strategy 投票，penalty 嚴重度減半。
#
# ENSEMBLE_NUMBER_EXPOSURE_WINDOW=10          # 統計最近幾期 prediction five_star
# ENSEMBLE_NUMBER_EXPOSURE_MAX_REPEAT=4       # 該視窗中 >= 此次數開始打 penalty（每多 1 次再乘一次）
# ENSEMBLE_NUMBER_EXPOSURE_PENALTY=0.80       # exposure 觸發倍率（0-1）
# ENSEMBLE_HOT_TOP10_MAX_RATIO=0.35           # final top10 中 trend-topK 號最高比例
# ENSEMBLE_HOT_TOP10_PENALTY=0.84             # 超出比例時，對 trend-topK 號 soft penalty 倍率
# ENSEMBLE_CORE_GROUP_PENALTY=0.82            # core group（過度進入 three_star）的 soft penalty
# ENSEMBLE_CORE_GROUP_WINDOW=10               # 統計最近幾期 three_star
# ENSEMBLE_CORE_GROUP_MAX_EXPOSURE=4          # 該視窗中 >= 此次數觸發
# ENSEMBLE_CONSENSUS_PROTECTION_MIN_SUPPORT=3 # support 達此值，penalty 嚴重度由 factor 調整
# ENSEMBLE_CONSENSUS_PROTECTION_FACTOR=0.50   # 0=完全保護、0.5=嚴重度減半、1=不保護

# ─── Structure Adjustment（輕量結構修正；預設關閉） ────────────────────────
# 在 ensemble_voting 之上加一層 soft 乘性微調（max ±W 倍率），
# 訊號：尾數平衡、區間輪替、GAP 回補、奇偶/大小、連號疲勞。全部 deterministic、無 hardcoded 號碼。
# 只在 ENSEMBLE_VOTING_ENABLED=true 才會生效。
# Rollback：STRUCTURE_ADJUST_ENABLED=false 或 STRUCTURE_ADJUST_WEIGHT=0。
# STRUCTURE_ADJUST_ENABLED=false              # 預設關閉
# STRUCTURE_ADJUST_WEIGHT=0.10                # ±10% 倍率上限；0=no-op、最大 0.5

# ─── Dynamic Window v1（soft 多視窗 re-weighting；預設關閉） ────────────────
# 詳細設計見 DYNAMIC_WINDOW_DESIGN.md。只在 ENSEMBLE_VOTING_ENABLED=true 才會生效。
# 訊號從真實歷史開獎多視窗加權頻率推導；deterministic、無隨機、無 hardcoded 號碼。
# Rollback：DYNAMIC_WINDOW_ENABLED=false。
# DYNAMIC_WINDOW_ENABLED=false                # 預設 false
# DYNAMIC_WINDOW_VERSION=dynamic_window_v1    # cache schema 後綴
# DYNAMIC_WINDOW_WEIGHT=0.05                  # 倍率上限（0=no-op，建議 0.05，最大 0.5）
# DYNAMIC_WINDOW_MIN_OBSERVATIONS=30          # draws 不足時 dormant
# DYNAMIC_WINDOW_MIN_WINDOW=10
# DYNAMIC_WINDOW_MAX_WINDOW=100
# DYNAMIC_WINDOW_W1=30                        # 視窗 1
# DYNAMIC_WINDOW_W1_WEIGHT=0.35
# DYNAMIC_WINDOW_W2=60
# DYNAMIC_WINDOW_W2_WEIGHT=0.30
# DYNAMIC_WINDOW_W3=70
# DYNAMIC_WINDOW_W3_WEIGHT=0.20
# DYNAMIC_WINDOW_W4=80
# DYNAMIC_WINDOW_W4_WEIGHT=0.15

# ─── Candidate Config — Variant C（Phase 2.5 推薦候選；預設仍 OFF） ────────
# 這不是 production 預設。複製貼上下面區塊（去掉 #）後即可啟用。
# 機制：exposure penalty + consensus protection 做有邏輯的輪替。
#   - 不是 random / 不是 blacklist / 不是 hard ban
#   - 不禁止 21/8/22/16/27 或任何號碼
#   - 號碼曝光過量 → deterministic soft penalty；3+ strategy 支持 → 嚴重度減半
# 建議使用順序：本機 cloud-readonly → Vercel Preview → 觀察 1-2 週 → 才決定 production
# Rollback：把 ENSEMBLE_VOTING_ENABLED 改為 false 或移除即可
#
# ENSEMBLE_VOTING_ENABLED=true                     # 候選版總開關
# ENSEMBLE_VOTING_VERSION=ensemble_voting_v1
# ENSEMBLE_NUMBER_EXPOSURE_MAX_REPEAT=3            # 預設 4 → 3（更早觸發 exposure penalty）
# ENSEMBLE_NUMBER_EXPOSURE_PENALTY=0.75            # 預設 0.80 → 0.75（稍嚴格）
# ENSEMBLE_CORE_GROUP_MAX_EXPOSURE=3               # 預設 4 → 3
# ENSEMBLE_CORE_GROUP_PENALTY=0.78                 # 預設 0.82 → 0.78
# # 其餘 ENSEMBLE_* / MULTI_STRATEGY_* 全部使用上方 Phase 2 / Phase 2.5 預設

# ─────────────────────────────────────────────────────────────────
#  backend/.env.cloud-readonly.example
#  本機 Cloud Readonly 開發模式範本
#
#  目的：本機可讀正式 Firestore（看到與雲端一樣的資料），
#       但所有 Firestore write/update/delete 都被 readonly guard 擋下。
#
#  使用方式：
#    cp backend/.env.cloud-readonly.example backend/.env
#    把 FIREBASE_* / ADMIN_RESET_TOKEN / CRON_SECRET 填入正式值
#    確認 CLOUD_READONLY=true
#    npm run dev
#
#  ⚠️ 本檔不含 secret，可 commit。實際 .env 不要 commit。
# ─────────────────────────────────────────────────────────────────

# 模式開關（必填）
APP_MODE=cloud
CLOUD_READONLY=true        # ← 必須為 true，否則本機會直接寫入 production
NODE_ENV=development

# Firebase 連線（必填，從 production 環境複製過來）
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Admin / Cron secret（建議與 production 相同；readonly 模式下也用不到 mutation）
ADMIN_RESET_TOKEN=
CRON_SECRET=

# Frontend (本機 dev 由 Vite 直接讀)
VITE_API_BASE_URL=http://localhost:3001/api

# 官方資料來源（與正式相同；readonly 模式不會觸發同步寫入）
TW_LOTTERY_RESULT_URL=https://www.taiwanlottery.com/lotto/result/4_d/
TW_LOTTERY_HISTORY_DOWNLOAD_URL=https://www.taiwanlottery.com/lotto/history/result_download/
TW_LOTTERY_HISTORY_RESULT_URL=https://www.taiwanlottery.com/lotto/history/history_result/
TW_LOTTERY_API_LATEST=
TW_LOTTERY_API_HISTORY_BASE=

# Strategy ENV：本機與正式必須一致，避免 prediction drift
# 以下 5 個 hidden kill-switch 預設皆為 0 / off，與正式 production 相同
# TOP_SCORE_COMPRESSION_DISABLED=0
# PLAN_B_TUNING_ENABLED=0
# POOL_DIVERSIFICATION_DISABLED=0
# SINGLE_ROTATION_DISABLED=0
# STRUCTURE_FATIGUE_REVERTED=0

# Anti-hot 主參數（與 default 相同，可省略）
# ANTIHOT_ENABLED=true
# ANTIHOT_WINDOW=5
# ANTIHOT_MIN_FACTOR=0.60

# Anti-hot selection 三參數（hidden，與 default 相同，可省略）
# ANTIHOT_SELECTION_PENALTY_ENABLED=true
# ANTIHOT_SELECTION_WINDOW=4
# ANTIHOT_SELECTION_MIN_FACTOR=0.50

# ─── multi_strategy_v1（5 策略 ensemble） ───────────────────────────
# 詳細說明：MULTI_STRATEGY_DESIGN.md
# 影響：prediction 結果（會影響 single/two_star/three_star/four_star/five_star 排序）
# Local/Cloud：兩端都用；本機與雲端必須完全一致，否則 prediction drift
# Production：是否啟用由你決定；啟用後新 cache 自動產生（schema 變更）
# 預設：關閉（commented out → baseline 行為，與升級前完全一致）
# MULTI_STRATEGY_ENABLED=true
# MULTI_STRATEGY_VERSION=multi_strategy_v1
# STRATEGY_WEIGHT_TREND=0.35
# STRATEGY_WEIGHT_BALANCE=0.20
# STRATEGY_WEIGHT_ANTI_CONCENTRATION=0.20
# STRATEGY_WEIGHT_REVERSION=0.15
# STRATEGY_WEIGHT_COVERAGE=0.10
# MULTI_STRATEGY_MIN_SUPPORT_FACTOR=0.40
# MULTI_STRATEGY_MAX_HOT_RATIO=0.60
# MULTI_STRATEGY_MIN_MID_COLD_RATIO=0.40
# MULTI_STRATEGY_RECENT_RECOMMEND_WINDOW=5
# MULTI_STRATEGY_PAIR_REPEAT_PENALTY=0.88
# MULTI_STRATEGY_TRIPLE_REPEAT_PENALTY=0.82
# MULTI_STRATEGY_REVERSION_BONUS=1.08
# MULTI_STRATEGY_COVERAGE_BONUS=1.06

# ─── ensemble_voting_v1（真正 meta voting；獨立於 multi_strategy_v1） ────────
# 詳細說明：ENSEMBLE_VOTING_DESIGN.md（Phase 3 文件）
# 影響：prediction 結果（重排 single/two/three/four/five_star）
# Local/Cloud：兩端都用；雲端與本機必須一致以避免 prediction drift
# Production：是否啟用由你決定；啟用後 cache schema 變更，舊 cache 失效；
#             cloud-readonly 下不會寫入 Firestore（readonly guard 保留生效）
# 預設：關閉（commented out → baseline / multi_strategy_v1 行為不變）
# Rollback：移除 ENSEMBLE_VOTING_ENABLED 或設 false 即可
#
# ENSEMBLE_VOTING_ENABLED=true
# ENSEMBLE_VOTING_VERSION=ensemble_voting_v1
# ENSEMBLE_TOP_K=10
# ENSEMBLE_MIN_SUPPORT_STRATEGIES=2
# ENSEMBLE_TREND_ONLY_PENALTY=0.72
# ENSEMBLE_MAX_TREND_ONLY_TOP10_RATIO=0.35
# ENSEMBLE_PAIR_LOCK_PENALTY=0.82
# ENSEMBLE_TRIPLE_LOCK_PENALTY=0.78
# ENSEMBLE_DOMINANCE_WINDOW=5
# ENSEMBLE_PAIR_LOCK_WINDOW=5
# ENSEMBLE_PAIR_LOCK_MAX_REPEAT=2
# ENSEMBLE_TRIPLE_LOCK_WINDOW=5
# ENSEMBLE_TRIPLE_LOCK_MAX_REPEAT=1
# ENSEMBLE_COVERAGE_TARGET=39
# ENSEMBLE_MAX_SINGLE_STRATEGY_DOMINANCE=0.40
# ENSEMBLE_STRATEGY_WEIGHT_TREND=0.22
# ENSEMBLE_STRATEGY_WEIGHT_BALANCE=0.22
# ENSEMBLE_STRATEGY_WEIGHT_ANTI_CONCENTRATION=0.22
# ENSEMBLE_STRATEGY_WEIGHT_REVERSION=0.17
# ENSEMBLE_STRATEGY_WEIGHT_COVERAGE=0.17

# Phase 2.5：核心群／號碼曝光 soft penalty
# Local/Cloud 必須一致；rollback：清掉 ENV 即可回 Phase 2 行為
# ENSEMBLE_NUMBER_EXPOSURE_WINDOW=10
# ENSEMBLE_NUMBER_EXPOSURE_MAX_REPEAT=4
# ENSEMBLE_NUMBER_EXPOSURE_PENALTY=0.80
# ENSEMBLE_HOT_TOP10_MAX_RATIO=0.35
# ENSEMBLE_HOT_TOP10_PENALTY=0.84
# ENSEMBLE_CORE_GROUP_PENALTY=0.82
# ENSEMBLE_CORE_GROUP_WINDOW=10
# ENSEMBLE_CORE_GROUP_MAX_EXPOSURE=4
# ENSEMBLE_CONSENSUS_PROTECTION_MIN_SUPPORT=3
# ENSEMBLE_CONSENSUS_PROTECTION_FACTOR=0.50

# ─── Candidate Config — Variant C（Phase 2.5 推薦候選；預設仍 OFF） ────────
# cloud-readonly 是觀察 Variant C 真實 production 資料的最佳環境：
#   - 看到正式 Firestore 資料
#   - Firestore guard 仍生效（不會誤寫）
#   - 可以連續觀察 1-2 週每日 prediction 的 rolling recent_10 / recent_30
# 機制：exposure penalty + consensus protection 做有邏輯輪替。
#   不是 random / 不是 blacklist / 不是 hard ban / 不禁止任何號碼。
# 上 production 前建議：本機 cloud-readonly → Vercel Preview → production
# Rollback：把 ENSEMBLE_VOTING_ENABLED 改為 false 或移除即可
#
# ENSEMBLE_VOTING_ENABLED=true
# ENSEMBLE_VOTING_VERSION=ensemble_voting_v1
# ENSEMBLE_NUMBER_EXPOSURE_MAX_REPEAT=3
# ENSEMBLE_NUMBER_EXPOSURE_PENALTY=0.75
# ENSEMBLE_CORE_GROUP_MAX_EXPOSURE=3
# ENSEMBLE_CORE_GROUP_PENALTY=0.78
# # 其他 ENSEMBLE_* 全部走預設
